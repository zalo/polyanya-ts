def distance_line_point(x1, y1, x2, y2, x0, y0)
	x12 = x2 - x1
	y12 = y2 - y1
	(x12 * (y1 - y0) - (x1 - x0) * y12).abs / Math.hypot(x12, y12)
end

def distance_line_point_squared(x1, y1, x2, y2, x0, y0)
	x12 = x2 - x1
	y12 = y2 - y1
	(x12 * (y1 - y0) - (x1 - x0) * y12) ** 2 / (x12 ** 2 + y12 ** 2)
end

