	def old_new_bor_list(a, b, n)
		a, b, n = a.vertex, b.vertex, n.vertex
		aax = a.x - n.x
		aay = a.y - n.y
		bbx = b.x - n.x
		bby = b.y - n.y
		l = Array.new
		aa = Math.atan2(aay, aax)
		ab = Math.atan2(bby, bbx)
		ab, aa = aa, ab if aa > ab
		n.neighbors.each{|el|
			an = Math.atan2(el.y - n.y, el.x - n.x)
			if ab - aa < Math::PI
				l << el if an > aa && an < ab
			else
				l << el if an < aa || an > ab
			end
		}
		l.delete(a)
		l.delete(b)
		return l
	end

