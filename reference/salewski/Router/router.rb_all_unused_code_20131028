			end
		end
		}
		l.delete(a)
		l.delete(b)
		return l
	end

	def bor_list(a, b, n)
		a, b, n = a.vertex, b.vertex, n.vertex
		aax = n.x - a.x
		aay = n.y - a.y
		bbx = b.x - n.x
		bby = b.y - n.y
		s = (aax * bby < aay * bbx)
		n.neighbors.select{|el| (el != a) && (el != b) && ((aax * (el.y - n.y) > aay * (el.x - n.x))) ^ s && ((bbx * (el.y - n.y) > bby * (el.x - n.x))) ^ s}
	end

